{
  "name": "smartcrop-pdf-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "ci": "npm run typecheck && eslint src && vitest run --coverage && playwright test"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "onnxruntime-web": "^1.19.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.6.82"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@playwright/test": "^1.46.0",
    "@techstark/opencv-js": "4.10.0-release.1",
    "@vitest/coverage-v8": "^2.0.5",
    "eslint": "^9.8.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vite-plugin-static-copy": "^3.4.0",
    "vitest": "^2.0.5"
  }
}
